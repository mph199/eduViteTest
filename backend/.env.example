# PostgreSQL Configuration
# Option A: Connection string (recommended)
DATABASE_URL=postgresql://sprechtag:sprechtag@postgres:5432/sprechtag

# SECURITY: In production, use strong random passwords!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# Option B: Individual parameters (used if DATABASE_URL is not set)
# DB_HOST=postgres
# DB_PORT=5432
# DB_NAME=sprechtag
# DB_USER=sprechtag
# DB_PASSWORD=sprechtag
# DB_SSL=false

# Server Configuration
PORT=4000

# Session Secret (CHANGE IN PRODUCTION! Use a random 64-char hex string)
SESSION_SECRET=your_secret_session_key_here

# Public Base URL for links in emails (frontend URL)
PUBLIC_BASE_URL=http://localhost:3000

# CORS – comma-separated list of allowed origins
# In Docker: typically just the frontend URL; without this, localhost defaults are used
CORS_ORIGINS=http://localhost:3000

# Verification token TTL (hours). After this, the verify link is considered expired.
VERIFICATION_TOKEN_TTL_HOURS=72

# SMTP configuration for sending emails
# Use Ethereal for dev/test email preview links
MAIL_TRANSPORT=ethereal
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL="Elternsprechtag <no-reply@example.com>"

# Docker Postgres (used by docker-compose for the postgres service)
POSTGRES_DB=sprechtag
POSTGRES_USER=sprechtag
POSTGRES_PASSWORD=sprechtag

# Aktivierte Module (kommasepariert). Leer = alle Module laden.
# Beispiel: ENABLED_MODULES=elternsprechtag,schulsozialarbeit
ENABLED_MODULES=
