# ── Frontend (Vite) ─────────────────────────────────────
# Backend API URL (optional, defaults to Render deployment)
VITE_API_URL=http://localhost:4000/api

# Aktivierte Frontend-Module (kommasepariert). Leer = alle Module laden.
# Muss mit ENABLED_MODULES im Backend uebereinstimmen.
# Beispiel: VITE_ENABLED_MODULES=elternsprechtag,schulsozialarbeit
VITE_ENABLED_MODULES=

# ── Backend: Server ────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:5173

# ── Backend: Datenbank ─────────────────────────────────
# Entweder DATABASE_URL ODER die einzelnen DB_*-Variablen setzen
# DATABASE_URL=postgresql://postgres:password@localhost:5432/sprechtag
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sprechtag
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# ── Backend: Authentifizierung ─────────────────────────
JWT_SECRET=
# SESSION_SECRET=  (Fallback fuer JWT_SECRET)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# ── Backend: E-Mail (SMTP) ────────────────────────────
# MAIL_TRANSPORT=ethereal  (fuer Entwicklung, kein SMTP noetig)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=no-reply@example.com

# ── Backend: Module ───────────────────────────────────
# Kommasepariert. Leer = alle Module.
ENABLED_MODULES=

# ── Backend: Token ────────────────────────────────────
VERIFICATION_TOKEN_TTL_HOURS=72

# ── Backend: Logging ──────────────────────────────────
LOG_LEVEL=debug

# ── DSGVO: Aufbewahrungsfristen (Tage, optional) ──────
# RETENTION_BOOKING_REQUESTS_DAYS=180
# RETENTION_SSW_APPOINTMENTS_DAYS=365
# RETENTION_BL_APPOINTMENTS_DAYS=365
# RETENTION_CANCELLED_DAYS=30
